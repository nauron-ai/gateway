{
  "db_name": "PostgreSQL",
  "query": "\n            UPDATE contexts\n            SET \n                title = COALESCE($2, title),\n                description = COALESCE($3, description),\n                mode = COALESCE($4, mode),\n                updated_at = NOW()\n            WHERE id = $1\n            RETURNING \n                id, \n                title, \n                description, \n                created_at, \n                updated_at, \n                owner_id,\n                mode as \"mode: ContextMode\",\n                (SELECT COUNT(*) FROM context_files cf WHERE cf.context_id = contexts.id) as \"files_count\"\n            ",
