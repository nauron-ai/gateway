{
  "db_name": "PostgreSQL",
  "query": "\n            SELECT\n                id,\n                service,\n                endpoint,\n                method,\n                status,\n                latency_ms,\n                response_bytes,\n                error,\n                created_at\n            FROM connection_events\n            WHERE created_at >= $2\n              AND ($3::text IS NULL OR service = $3)\n            ORDER BY created_at DESC\n            LIMIT $1\n            ",
