  "db_name": "PostgreSQL",
  "query": "\n            UPDATE files\n            SET status = 'processing'::file_status,\n                mir_job_id = $2,\n                doc_id = COALESCE(doc_id, $2),\n                updated_at = now()\n            WHERE id = $1\n            RETURNING\n                id,\n                doc_id,\n                sha256,\n                size_bytes,\n                mime,\n                storage_bucket,\n                storage_key,\n                status as \"status: FileStatus\",\n                mir_job_id,\n                mir_artifact_uri,\n                mir_artifact_sha256,\n                mir_processed_at,\n                created_at,\n                updated_at\n            ",
